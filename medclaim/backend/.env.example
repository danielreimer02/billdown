# Backend — copy to .env and fill in
SECRET_KEY=your-secret-key-here-change-this
DATABASE_URL=postgresql://medclaim:medclaim@postgres:5432/medclaim
REDIS_URL=redis://redis:6379/0
ENVIRONMENT=development

# AWS (for Textract fallback on scanned docs)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Digital Ocean Spaces (S3-compatible)
# Use same AWS keys as above but point to DO endpoint
AWS_S3_BUCKET=medclaim-documents
